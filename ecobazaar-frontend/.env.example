# Frontend Environment Variables — Example
# Copy this to .env for local development and fill in values.
# For production, set these in the Vercel dashboard (never commit .env).

# URL of your deployed backend (Render)
# Production: https://<your-render-app>.onrender.com/api
# Local dev:  http://localhost:8081/api
VITE_API_BASE_URL=http://localhost:8081/api
